<div style="font-family: Arial, sans-serif; max-width: 800px; margin: 60px auto; text-align: center; background: #ffffff; padding: 40px; border-radius: 18px; box-shadow: 0 6px 24px rgba(0,0,0,0.08);">
  <h1 style="margin-bottom: 10px; color: #111827;">AI Research Explorer</h1>
  <p style="color: #6b7280; margin-bottom: 30px; font-size: 17px;">
    A small Ruby on Rails project inspired by AI, space, evolution, and simulation research.
  </p>

  <form action="/" method="get" style="margin-bottom: 20px;">
    <input
        type="text"
        name="name"
        placeholder="Enter your name"
        value="<%= @name %>"
        style="padding: 12px; width: 220px; font-size: 16px; border: 1px solid #d1d5db; border-radius: 8px;"
    >

    <select
        name="domain"
        style="padding: 12px; width: 220px; font-size: 16px; border: 1px solid #d1d5db; border-radius: 8px; margin-left: 10px;"
    >
        <option value="">Select research domain</option>
        <option value="AI Learning" <%= "selected" if @domain == "AI Learning" %>>AI Learning</option>
        <option value="Space Biology" <%= "selected" if @domain == "Space Biology" %>>Space Biology</option>
        <option value="Artificial Evolution" <%= "selected" if @domain == "Artificial Evolution" %>>Artificial Evolution</option>
        <option value="Consciousness" <%= "selected" if @domain == "Consciousness" %>>Consciousness</option>
        <option value="Cosmic Simulation" <%= "selected" if @domain == "Cosmic Simulation" %>>Cosmic Simulation</option>
    </select>

    <button
        type="submit"
        style="padding: 12px 20px; font-size: 16px; margin-left: 10px; border: none; background: #2563eb; color: white; border-radius: 8px; cursor: pointer;"
    >
        Explore
    </button>
    </form>

  <% if @message.present? %>
    <div style="margin-top: 25px; padding: 18px; background: #eff6ff; color: #1e3a8a; border-radius: 12px;">
      <h2 style="margin: 0 0 10px 0;"><%= @message %></h2>
      <p style="margin: 0; font-size: 15px;">Current server time: <%= @time %></p>
    </div>

    <div style="margin-top: 25px; text-align: left; background: #f9fafb; padding: 24px; border-radius: 12px; border-left: 6px solid #2563eb;">
      <h3 style="margin-top: 0; color: #111827;">Research Theme: <%= @selected_title || @selected_topic[:title] %></h3>
      <p style="color: #374151; line-height: 1.7; font-size: 16px;">
        <%= @selected_idea || @selected_topic[:idea] %>
      </p>
    </div>
  <% elsif @error.present? %>
    <div style="margin-top: 25px; padding: 14px; background: #fef2f2; color: #991b1b; border-radius: 10px; font-weight: bold;">
      <%= @error %>
    </div>
  <% end %>

  <div style="margin-top: 30px;">
    <a href="/about" style="text-decoration: none; color: #2563eb; font-weight: bold;">About this project</a>
  </div>
</div>